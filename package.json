{
  "name": "edullm-profesor-backend",
  "version": "1.0.0",
  "description": "Microservicio backend para el módulo de profesores - eduLLM",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npx prisma generate && nodemon server.js",
